rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Open to all signed-in users ───────────────────────────────
    // Any authenticated user can read and write any document.
    // Simple and correct for a community app — tighten per-collection later.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}
